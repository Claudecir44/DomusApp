<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F0F2F8"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Listas"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnListaMoradores"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Lista de Moradores"
        android:textSize="16sp"
        android:backgroundTint="#6E747E"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:cornerRadius="8dp"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnListaAssembleias"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Lista de Assembleias"
        android:textSize="16sp"
        android:backgroundTint="#6E747E"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:cornerRadius="8dp"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnListaDespesas"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Prestação de Contas"
        android:textSize="16sp"
        android:backgroundTint="#6E747E"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:cornerRadius="8dp"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnListaAvisos"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Avisos"
        android:textSize="16sp"
        android:backgroundTint="#6E747E"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:cornerRadius="8dp"/>

</LinearLayout>