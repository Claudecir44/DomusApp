<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F8"
    tools:context=".LoginMasterActivity">

    <!-- Título -->
    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Login Master"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp" />

    <!-- Subtítulo 1 -->
    <TextView
        android:id="@+id/txtSubtitulo1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Entre com as Credenciais para Primeiro Acesso"
        android:textSize="14sp"
        android:textColor="#6B7280"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtítulo 2 -->
    <TextView
        android:id="@+id/txtSubtitulo2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Usuário: &quot;admin&quot;   Senha: &quot;master&quot;"
        android:textSize="12sp"
        android:textColor="#9CA3AF"
        android:gravity="center"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/txtSubtitulo1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Campo Administrador -->
    <EditText
        android:id="@+id/editUsuario"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:hint="Administrador"
        android:inputType="text"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@drawable/edittext_background"
        android:textSize="14sp"
        android:textColor="#1A1A2E"
        android:textColorHint="#9CA3AF"
        app:layout_constraintTop_toBottomOf="@id/txtSubtitulo2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="32dp" />

    <!-- Campo Senha -->
    <EditText
        android:id="@+id/editSenha"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:hint="Senha"
        android:inputType="textPassword"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@drawable/edittext_background"
        android:textSize="14sp"
        android:textColor="#1A1A2E"
        android:textColorHint="#9CA3AF"
        app:layout_constraintTop_toBottomOf="@id/editUsuario"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="2dp" />

    <!-- Botão Entrar -->
    <Button
        android:id="@+id/btnEntrar"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:text="Entrar"
        android:textAllCaps="false"
        android:backgroundTint="#6E747E"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:letterSpacing="0.03"
        android:elevation="2dp"
        app:cornerRadius="8dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/editSenha"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>