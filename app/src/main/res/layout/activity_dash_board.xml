<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F0F2F8">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F0F2F8"
        android:paddingBottom="16dp"
        tools:context=".DashBoardActivity">

        <TextView
            android:id="@+id/textTitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Administração"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp"/>

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

        <!-- ========== BOTÕES ADMIN ========== -->
        <Button
            android:id="@+id/buttonAdministradores"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#6E747E"
            android:text="Administradores"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            app:cornerRadius="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/guideline"
            app:layout_constraintTop_toBottomOf="@id/textTitulo" />

        <Button
            android:id="@+id/buttonAssembleias"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#6E747E"
            android:text="Assembleias"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            app:cornerRadius="8dp"
            app:layout_constraintStart_toEndOf="@id/guideline"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textTitulo" />

        <Button
            android:id="@+id/buttonDespesas"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#6E747E"
            android:text="Despesas"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            app:cornerRadius="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/guideline"
            app:layout_constraintTop_toBottomOf="@id/buttonAdministradores" />

        <Button
            android:id="@+id/buttonAvisos"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#6E747E"
            android:text="Avisos"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            app:cornerRadius="8dp"
            app:layout_constraintStart_toEndOf="@id/guideline"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/buttonAssembleias" />

        <Button
            android:id="@+id/buttonCadastroMoradores"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#6E747E"
            android:text="Moradores"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            app:cornerRadius="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/guideline"
            app:layout_constraintTop_toBottomOf="@id/buttonDespesas" />

        <Button
            android:id="@+id/buttonRegistroOcorrencias"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#6E747E"
            android:text="Ocorrências"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            app:cornerRadius="8dp"
            app:layout_constraintStart_toEndOf="@id/guideline"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/buttonAvisos" />

        <Button
            android:id="@+id/buttonManutencao"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#6E747E"
            android:text="Manutenção"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            app:cornerRadius="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/guideline"
            app:layout_constraintTop_toBottomOf="@id/buttonCadastroMoradores" />

        <Button
            android:id="@+id/buttonFuncionarios"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#6E747E"
            android:text="Funcionários"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            app:cornerRadius="8dp"
            app:layout_constraintStart_toEndOf="@id/guideline"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/buttonRegistroOcorrencias" />

        <View
            android:id="@+id/espacoMorador"
            android:layout_width="0dp"
            android:layout_height="20dp"
            app:layout_constraintTop_toBottomOf="@id/buttonFuncionarios"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ========== BOTÕES DO MORADOR (apenas os que ficam na Dashboard) ========== -->
        <!-- Prestação de Contas (esquerda) -->
        <Button
            android:id="@+id/buttonListaDespesas"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#6E747E"
            android:text="Prestação de Contas"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            app:cornerRadius="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/guideline"
            app:layout_constraintTop_toBottomOf="@id/espacoMorador" />

        <!-- Avisos (direita) -->
        <Button
            android:id="@+id/buttonAvisosMorador"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#6E747E"
            android:text="Avisos"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            app:cornerRadius="8dp"
            app:layout_constraintStart_toEndOf="@id/guideline"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/espacoMorador" />

        <!-- ========== BOTÃO "LISTAS" (ADMIN E MORADOR) ========== -->
        <!-- Agora ocupa a largura total e fica abaixo dos botões acima -->
        <Button
            android:id="@+id/buttonListas"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#6E747E"
            android:text="Listas"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            app:cornerRadius="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/buttonAvisosMorador"
            android:layout_marginBottom="0dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>