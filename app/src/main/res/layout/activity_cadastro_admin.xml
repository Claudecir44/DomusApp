<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/editNomeAdmin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nome do Administrador" />

    <EditText
        android:id="@+id/editEmailAdmin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="E-mail"
        android:inputType="textEmailAddress" />

    <EditText
        android:id="@+id/editSenhaAdmin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Senha (6 dígitos)"
        android:inputType="numberPassword" />

    <EditText
        android:id="@+id/editTelefoneAdmin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Telefone (opcional)"
        android:inputType="phone" />

    <Button
        android:id="@+id/btnCadastrarAdmin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cadastrar Administrador" />
</LinearLayout>