<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="20dp"
    android:layout_marginEnd="20dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Linha com foto e dados -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Foto do funcionário -->
            <ImageView
                android:id="@+id/ivFuncionarioFoto"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginEnd="16dp"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_camera"
                android:contentDescription="Foto do Funcionário"
                android:background="#E0E0E0"
                android:padding="2dp"/>

            <!-- Dados do funcionário -->
            <TextView
                android:id="@+id/tvFuncionarioDados"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#374151"
                android:textSize="14sp"
                android:ellipsize="none"
                android:scrollHorizontally="false"
                android:text="Nome: \nRua: \nNúmero: \nBairro: \nCEP: \nCidade: \nEstado: \nPaís: \nTelefone: \nEmail: \nRG: \nCPF: \nCarga Horária: \nTurno: \nEntrada: \nSaída:" />
        </LinearLayout>

        <!-- Botões de ação -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btnEditarFuncionario"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Editar"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.03"
                android:textAllCaps="false"
                android:backgroundTint="#3B82F6"
                android:textColor="#FFFFFF"
                app:cornerRadius="6dp"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnExcluirFuncionario"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Excluir"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.03"
                android:textAllCaps="false"
                android:backgroundTint="#EF4444"
                android:textColor="#FFFFFF"
                app:cornerRadius="6dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>