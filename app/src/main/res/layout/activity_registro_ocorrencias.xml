<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F0F2F8">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp"
        tools:context=".RegistroOcorrenciasActivity">

        <!-- Título -->
        <TextView
            android:id="@+id/textTitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Registrar Ocorrências"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:gravity="center"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Tipo/Nome da ocorrência -->
        <EditText
            android:id="@+id/editTipo"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="24dp"
            android:hint="Tipo/Nome da Ocorrência"
            android:inputType="textCapWords"
            android:background="@drawable/edittext_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textSize="14sp"
            android:textColor="#1A1A2E"
            android:textColorHint="#9CA3AF"
            app:layout_constraintTop_toBottomOf="@id/textTitulo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Data e hora da ocorrência -->
        <EditText
            android:id="@+id/editDataHora"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="2dp"
            android:hint="Data e hora"
            android:focusable="false"
            android:clickable="true"
            android:background="@drawable/edittext_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textSize="14sp"
            android:textColor="#1A1A2E"
            android:textColorHint="#9CA3AF"
            app:layout_constraintTop_toBottomOf="@id/editTipo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Nome dos envolvidos -->
        <LinearLayout
            android:id="@+id/layoutEnvolvidos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/editDataHora"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/editEnvolvido1"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:hint="Nome do envolvido 1"
                android:background="@drawable/edittext_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="14sp"
                android:textColor="#1A1A2E"
                android:textColorHint="#9CA3AF" />

            <EditText
                android:id="@+id/editEnvolvido2"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="2dp"
                android:hint="Nome do envolvido 2"
                android:background="@drawable/edittext_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="14sp"
                android:textColor="#1A1A2E"
                android:textColorHint="#9CA3AF" />

            <EditText
                android:id="@+id/editEnvolvido3"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="2dp"
                android:hint="Nome do envolvido 3"
                android:background="@drawable/edittext_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="14sp"
                android:textColor="#1A1A2E"
                android:textColorHint="#9CA3AF" />

            <EditText
                android:id="@+id/editEnvolvido4"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="2dp"
                android:hint="Nome do envolvido 4"
                android:background="@drawable/edittext_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="14sp"
                android:textColor="#1A1A2E"
                android:textColorHint="#9CA3AF" />

            <EditText
                android:id="@+id/editEnvolvido5"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="2dp"
                android:hint="Nome do envolvido 5"
                android:background="@drawable/edittext_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="14sp"
                android:textColor="#1A1A2E"
                android:textColorHint="#9CA3AF" />
        </LinearLayout>

        <!-- Descrição da ocorrência -->
        <EditText
            android:id="@+id/editDescricao"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="2dp"
            android:hint="Descrição da ocorrência"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:background="@drawable/edittext_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:textSize="14sp"
            android:textColor="#1A1A2E"
            android:textColorHint="#9CA3AF"
            app:layout_constraintTop_toBottomOf="@id/layoutEnvolvidos"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Botão anexar arquivos -->
        <Button
            android:id="@+id/buttonAnexarArquivos"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="#6E747E"
            android:elevation="2dp"
            android:letterSpacing="0.03"
            android:text="Anexar arquivos (PDF, Word, Excel)"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            app:layout_constraintTop_toBottomOf="@id/editDescricao"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Lista de arquivos anexados -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerAnexos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="4dp"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/buttonAnexarArquivos"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Botão salvar -->
        <Button
            android:id="@+id/buttonSalvar"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="#6E747E"
            android:elevation="2dp"
            android:letterSpacing="0.03"
            android:text="Salvar Ocorrência"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            app:layout_constraintTop_toBottomOf="@id/recyclerAnexos"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Botão lista de ocorrências -->
        <Button
            android:id="@+id/buttonListaOcorrencias"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="2dp"
            android:backgroundTint="#6E747E"
            android:elevation="2dp"
            android:letterSpacing="0.03"
            android:text="Lista de Ocorrências"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            app:layout_constraintTop_toBottomOf="@id/buttonSalvar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>