<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F8"
    tools:context=".FuncionariosActivity">

    <!-- Título -->
    <TextView
        android:id="@+id/textTituloFuncionarios"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Gestão de Funcionários"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>

    <!-- Botão Cadastro Funcionário -->
    <Button
        android:id="@+id/buttonCadastroFuncionario"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:text="Cadastro de Funcionário"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:letterSpacing="0.03"
        android:elevation="2dp"
        android:backgroundTint="#6E747E"
        app:cornerRadius="8dp"
        app:layout_constraintTop_toBottomOf="@id/textTituloFuncionarios"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="32dp"/>

    <!-- Botão Lista de Funcionários -->
    <Button
        android:id="@+id/buttonListaFuncionarios"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:text="Lista de Funcionários"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:letterSpacing="0.03"
        android:elevation="2dp"
        android:backgroundTint="#6E747E"
        app:cornerRadius="8dp"
        app:layout_constraintTop_toBottomOf="@id/buttonCadastroFuncionario"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="2dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>